Content-Type: application/json

{
  "email": "seller@test.com",
  "password": "Password123!"
}

### Login Buyer
POST {{host}}/auth/login
Content-Type: application/json

{
  "email": "buyer@test.com",
  "password": "Password123!"
}

### Search RAWG for games (Requires: SellerToken)
GET {{host}}/rawg/search?query=Tears%20of%20the%20Kingdom
Authorization: Bearer {{sellerToken}}

### Get RAWG game details (Requires: SellerToken)
GET {{host}}/rawg/games/3327
Authorization: Bearer {{sellerToken}}

### Import game from RAWG (Requires: SellerToken)
POST {{host}}/rawg/import
Authorization: Bearer {{sellerToken}}
Content-Type: application/json

{
  "rawgId": 327239
}

###
DELETE {{host}}/games/1
Authorization: Bearer {{sellerToken}}

### Get all games — paginated (Public)
GET {{host}}/games?page=1&pageSize=10

### Get games — filtered by genre (Public)
GET {{host}}/games?genreId=3

### Get games — search by title (Public)
GET {{host}}/games?search=witcher

### Get games — sorted by release date descending (Public)
GET {{host}}/games?sortBy=releaseDate&sortOrder=desc

### Get game details (Public)
GET {{host}}/games/1

### Add game to catalog manually (Requires: SellerToken)
POST {{host}}/games
Authorization: Bearer {{sellerToken}}
Content-Type: application/json

{
  "title": "Moja Gra",
  "creators": "My Studio",
  "publishers": "My Publisher",
  "genreIds": [1],
  "platformIds": [1],
  "imageUrl": "https://example.com/image.jpg",
  "releaseDate": "2024-01-01"
}

### Add offer (Requires: SellerToken)
POST {{host}}/games/3/offers
Authorization: Bearer {{sellerToken}}
Content-Type: application/json

{
  "price": 19.99,
  "stock": 10,
  "platformId": 1
}
###

POST {{host}}/games/1/offers/2/discount
Authorization: Bearer {{sellerToken}}
Content-Type: application/json

{
  "discountPercentage": 90
}

### Get offers for a game (Public)
GET {{host}}/games/1/offers

### Update offer (Requires: SellerToken)
PUT {{host}}/games/1/offers/1
Authorization: Bearer {{sellerToken}}
Content-Type: application/json

{
  "price": 149.99,
  "stock": 20
}

### Delete offer (Requires: SellerToken)
DELETE {{host}}/games/1/offers/1
Authorization: Bearer {{sellerToken}}

### Place order (Requires: BuyerToken)
POST {{host}}/orders
Authorization: Bearer {{buyerToken}}
Content-Type: application/json

{
  "items": [
    { "gameOfferId": 1, "quantity": 3 }
  ]
}

### Get buyer orders (Requires: BuyerToken)
GET {{host}}/orders
Authorization: Bearer {{buyerToken}}

### Get order details (Requires: BuyerToken)
GET {{host}}/orders/1
Authorization: Bearer {{buyerToken}}

### Cancel order (Requires: BuyerToken)
POST {{host}}/orders/1/cancel
Authorization: Bearer {{buyerToken}}

### Get all genres (Public)
GET {{host}}/genres

### Get all platforms (Public)
GET {{host}}/platforms
