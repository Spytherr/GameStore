@host = http://localhost:5012

@sellerToken = YOUR_SELLER_TOKEN_HERE
@buyerToken = YOUR_BUYER_TOKEN_HERE

### Register Seller
POST {{host}}/auth/register
Content-Type: application/json

{
  "email": "seller@test.com",
  "displayName": "Janusz Biznesu",
  "password": "Password123!",
  "role": "Seller"
}

### Register Buyer
POST {{host}}/auth/register
Content-Type: application/json

{
  "email": "buyer@test.com",
  "displayName": "Kowalski",
  "password": "Password123!",
  "role": "Buyer"
}

### Login Seller
POST {{host}}/auth/login
Content-Type: application/json

{
  "email": "seller@test.com",
  "password": "Password123!"
}

### Login Buyer
POST {{host}}/auth/login
Content-Type: application/json

{
  "email": "buyer@test.com",
  "password": "Password123!"
}

### Get all games — paginated (Public)
GET {{host}}/games?page=1&pageSize=10

### Get games — filtered by genre (Public)
GET {{host}}/games?genreId=3

### Get games — search by title (Public)
GET {{host}}/games?search=witcher

### Get games — sorted by release date descending (Public)
GET {{host}}/games?sortBy=releaseDate&sortOrder=desc

### Get game details (Public)
GET {{host}}/games/1

### Add game to catalog (Requires: SellerToken)
POST {{host}}/games
Authorization: Bearer {{sellerToken}}
Content-Type: application/json

{
  "title": "Wiedźmin 3: Dziki Gon",
  "description": "Najlepsza gra RPG",
  "genreId": 3,
  "imageUrl": "https://example.com/witcher3.jpg",
  "releaseDate": "2015-05-19"
}

### Add game — validation error test (empty title)
POST {{host}}/games
Authorization: Bearer {{sellerToken}}
Content-Type: application/json

{
  "title": "",
  "genreId": 3,
  "releaseDate": "2020-01-01"
}

### Add offer (Requires: SellerToken)
POST {{host}}/games/1/offers
Authorization: Bearer {{sellerToken}}
Content-Type: application/json

{
  "price": 149.99,
  "stock": 10
}

### Get offers for a game (Public)
GET {{host}}/games/1/offers

### Update offer (Requires: SellerToken)
PUT {{host}}/games/1/offers/1
Authorization: Bearer {{sellerToken}}
Content-Type: application/json

{
  "price": 129.99,
  "stock": 15
}

### Place order (Requires: BuyerToken)
POST {{host}}/orders
Authorization: Bearer {{buyerToken}}
Content-Type: application/json

{
  "items": [
    { "gameOfferId": 1, "quantity": 3 }
  ]
}

### Get buyer orders (Requires: BuyerToken)
GET {{host}}/orders
Authorization: Bearer {{buyerToken}}

### Get order details (Requires: BuyerToken)
GET {{host}}/orders/1
Authorization: Bearer {{buyerToken}}

### Cancel order (Requires: BuyerToken)
POST {{host}}/orders/1/cancel
Authorization: Bearer {{buyerToken}}

### Get all genres (Public)
GET {{host}}/genres
